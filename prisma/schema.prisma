generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContactStatus {
  active
  archived
}

enum MessageKind {
  initial
  followup
}

enum ProviderType {
  resend
}

enum SendStatus {
  queued
  accepted
  sent
  delivered
  failed
  bounced
  complained
  canceled
}

enum ResponseStatus {
  unknown
  replied
  no_response
}

enum FollowupState {
  none
  due
  drafted
  sent
  skipped
  closed
}

enum FollowupDraftStatus {
  pending_review
  approved
  sent
  discarded
}

enum TemplateKind {
  initial
  followup
}

model Contact {
  id        String        @id @default(cuid())
  userId    String
  email     String
  name      String?
  company   String?
  status    ContactStatus @default(active)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages       OutreachMessage[]
  followupDrafts FollowupDraft[]

  @@unique([userId, email])
  @@index([userId, status])
}

model Template {
  id          String       @id @default(cuid())
  userId      String?
  kind        TemplateKind
  name        String
  focusType   String?
  subject     String
  bodyText    String
  bodyHtml    String?
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  followupDrafts FollowupDraft[]

  @@index([userId, kind])
}

model OutreachMessage {
  id               String         @id @default(cuid())
  userId           String
  contactId        String
  kind             MessageKind
  sequenceNumber   Int            @default(0)
  parentMessageId  String?
  subject          String
  bodyText         String
  bodyHtml         String?
  provider         ProviderType   @default(resend)
  providerMessageId String?
  sendStatus       SendStatus     @default(queued)
  responseStatus   ResponseStatus @default(unknown)
  followupState    FollowupState  @default(none)
  scheduledAt      DateTime?
  sentAt           DateTime?
  deliveredAt      DateTime?
  failedAt         DateTime?
  nextFollowupDueAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  parentMessage OutreachMessage? @relation("MessageFollowups", fields: [parentMessageId], references: [id], onDelete: SetNull)
  followups     OutreachMessage[] @relation("MessageFollowups")
  events        MessageEvent[]
  followupDrafts FollowupDraft[]

  @@index([userId, sendStatus])
  @@index([contactId, createdAt])
  @@index([nextFollowupDueAt, followupState])
  @@unique([provider, providerMessageId])
}

model MessageEvent {
  id               String   @id @default(cuid())
  messageId        String
  providerEventId  String?
  eventType        String
  eventAt          DateTime @default(now())
  payloadJson      String?
  createdAt        DateTime @default(now())

  message OutreachMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, eventAt])
  @@unique([providerEventId])
}

model FollowupDraft {
  id            String             @id @default(cuid())
  messageId     String
  contactId     String
  userId        String
  templateId    String?
  subjectDraft  String
  bodyDraft     String
  dueAt         DateTime
  status        FollowupDraftStatus @default(pending_review)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  message  OutreachMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  contact  Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  template Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, status, dueAt])
  @@index([messageId, status])
}
